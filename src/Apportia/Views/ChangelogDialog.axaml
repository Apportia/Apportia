<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apportia.Views.ChangelogDialog"
        Title="Update Available"
        Width="640"
        Height="560"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <StackPanel Grid.Row="0" Margin="20,18,20,14" Spacing="3">
            <TextBlock x:Name="VersionText"
                       FontSize="16" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="Review the changes below before installing."
                       FontSize="13"
                       Foreground="{DynamicResource AppSubTextBrush}" />
        </StackPanel>

        <Border Grid.Row="1" Height="1" Background="{DynamicResource AppSeparatorBrush}" />

        <ScrollViewer Grid.Row="2"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      Padding="20,10,0,10">
            <StackPanel Margin="0,0,20,0">
                <StackPanel x:Name="ChangelogPanel" />
                <Border Height="40" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="20,12" Spacing="8">
                <Button Content="Install Update" Click="OnInstall" />
                <Button Content="Cancel" Click="OnCancel" />
            </StackPanel>
        </Border>

    </Grid>
</Window>