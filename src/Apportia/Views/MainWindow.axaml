<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Apportia.ViewModels"
        xmlns:views="using:Apportia.Views"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Apportia"
        Icon="avares://Apportia/Assets/ProgramIcon.ico"
        Width="1024"
        Height="720"
        MinWidth="840"
        MinHeight="400"
        Background="{DynamicResource AppWindowBrush}">

    <Window.Styles>
        <Style Selector="#TopToolbar Button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <Style Selector="#TopToolbar TextBox:disabled /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource TextControlBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource TextControlBorderBrush}" />
        </Style>
        <Style Selector="Border.skeletonBase">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
        </Style>
        <Style Selector="Border.skeletonShimmer">
            <Setter Property="IsHitTestVisible" Value="False" />
            <Setter Property="Background">
                <LinearGradientBrush StartPoint="0%,50%" EndPoint="100%,50%">
                    <GradientStop Color="{DynamicResource AppShimmerEdgeColor}" Offset="0.0" />
                    <GradientStop Color="{DynamicResource AppShimmerHighlightColor}" Offset="0.5" />
                    <GradientStop Color="{DynamicResource AppShimmerEdgeColor}" Offset="1.0" />
                </LinearGradientBrush>
            </Setter>
        </Style>
        <Style Selector="Border.categoryHeader">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="CornerRadius" Value="4,4,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.categoryHeader TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="Border.subCategoryHeader">
            <Setter Property="Background" Value="{DynamicResource AppCategoryBrush}" />
            <Setter Property="Opacity" Value="0.75" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Margin" Value="8,4,0,0" />
            <Setter Property="CornerRadius" Value="4,4,0,0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.subCategoryHeader TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="Border.columnHeader">
            <Setter Property="Background" Value="{DynamicResource AppColHeaderBrush}" />
            <Setter Property="Padding" Value="0,3" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSeparatorBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="Border.columnHeader TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppSubTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Border.appRow">
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSeparatorBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>
        <Style Selector="Border.appRow.indentedRow">
            <Setter Property="Margin" Value="16,0,0,0" />
        </Style>
        <Style Selector="Border.appRow.installedRow">
            <Setter Property="Background" Value="{DynamicResource AppInstalledBrush}" />
        </Style>
        <Style Selector="Border.appRow.updateRow">
            <Setter Property="Background" Value="{DynamicResource AppUpdateBrush}" />
        </Style>
        <Style Selector="Border.appRow.queuedRow">
            <Setter Property="Background" Value="{DynamicResource AppQueuedBrush}" />
        </Style>
        <Style Selector="Border.appRow.activeInstallRow">
            <Setter Property="Background" Value="{DynamicResource AppActiveInstallBrush}" />
        </Style>
        <Style Selector="Button#LinuxSetupButton">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button#LinuxSetupButton.update">
            <Setter Property="Background" Value="{DynamicResource AppUpdateBrush}" />
        </Style>
        <Style Selector="Button#LinuxSetupButton.update:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppUpdateBrush}" />
        </Style>
        <Style Selector="Border.appRow.launchFxRow">
            <Style.Animations>
                <Animation Duration="0:0:0.7" IterationCount="INFINITE">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1.0" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Opacity" Value="0.4" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.appRow.searchFxRow">
            <Style.Animations>
                <Animation Duration="0:0:1.6" FillMode="None">
                    <KeyFrame Cue="0%">
                        <Setter Property="Background" Value="#CC0090FF" />
                    </KeyFrame>
                    <KeyFrame Cue="25%">
                        <Setter Property="Background" Value="#000090FF" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="Background" Value="#CC0090FF" />
                    </KeyFrame>
                    <KeyFrame Cue="75%">
                        <Setter Property="Background" Value="#000090FF" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Background" Value="#000090FF" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <Style Selector="Border.appRow:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
        </Style>
        <Style Selector="Border.appRow TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>
        <Style Selector="Thumb.colResizer">
            <Setter Property="Width" Value="5" />
            <Setter Property="Cursor" Value="SizeWestEast" />
            <Setter Property="Template">
                <ControlTemplate TargetType="Thumb">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Thumb.colResizer:pointerover">
            <Setter Property="Template">
                <ControlTemplate TargetType="Thumb">
                    <Border Background="{DynamicResource AppSeparatorBrush}" />
                </ControlTemplate>
            </Setter>
        </Style>
    </Window.Styles>

    <DockPanel>

        <Border x:Name="TopToolbar" DockPanel.Dock="Top" Padding="8,6" IsEnabled="False">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center">
                    <Button x:Name="SaveViewButton"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.SaveViewPreset}"
                            Click="OnSaveView">
                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4be.svg" Width="18" Height="18" />
                    </Button>
                    <Button x:Name="IconSizeButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.IconSize}"
                            Click="OnIconSizeCycle"
                            PointerReleased="OnIconSizePointerReleased" />
                    <Button x:Name="ViewModeButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.ViewMode}"
                            Click="OnViewModeToggle"
                            PointerReleased="OnViewModePointerReleased" />
                    <Button x:Name="FontSizeButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.FontSize}"
                            Click="OnFontSizeCycle"
                            PointerReleased="OnFontSizePointerReleased" />
                    <Button x:Name="CategoryScopeButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.CategoryScope}"
                            Click="OnCategoryScopeCycle"
                            PointerReleased="OnCategoryScopePointerReleased" />
                    <Button x:Name="CategoryDisplayButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.CategoryDisplay}"
                            Click="OnCategoryDisplayCycle"
                            PointerReleased="OnCategoryDisplayPointerReleased" />
                    <Button x:Name="InstallFilterButton"
                            VerticalAlignment="Center"
                            Padding="6,3"
                            FontSize="11"
                            Background="Transparent"
                            BorderThickness="0"
                            Opacity="0.6"
                            ToolTip.Tip="{x:Static text:UiText+Tip.InstallFilter}"
                            Click="OnInstallFilterCycle"
                            PointerReleased="OnInstallFilterPointerReleased" />
                </StackPanel>
                <AutoCompleteBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 HorizontalAlignment="Center"
                                 MinWidth="280"
                                 MaxWidth="480"
                                 PlaceholderText="{Binding SearchPlaceholder}"
                                 FilterMode="None"
                                 DropDownClosed="OnSearchDropDownClosed"
                                 KeyDown="OnSearchKeyDown" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button x:Name="UpdateButton"
                            IsVisible="False"
                            VerticalAlignment="Center"
                            Height="28"
                            FontSize="13"
                            ToolTip.Tip="{x:Static text:UiText+Tip.UpdateApportia}"
                            Click="OnUpdateApp" />
                    <Button x:Name="TerminateAllButton"
                            IsVisible="False"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.TerminateAllApps}"
                            Click="OnTerminateAllApps">
                        <svg:Svg Path="avares://Apportia/Assets/Emoji/2620.svg" Width="18" Height="18" />
                    </Button>
                    <Button x:Name="LinuxSetupButton"
                            IsVisible="False"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.WineSetup}"
                            Click="OnLinuxSetupButton">
                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f377.svg" Width="18" Height="18" />
                    </Button>
                    <Button x:Name="ImportApp"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.ImportCustomApp}"
                            Click="OnImportApp">
                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg" Width="18" Height="18" />
                    </Button>
                    <Button x:Name="ThemeToggleButton"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.ToggleTheme}"
                            Click="OnThemeToggle"
                            PointerReleased="OnThemePointerReleased">
                        <svg:Svg x:Name="ThemeToggleIcon" Path="avares://Apportia/Assets/Emoji/1f31e.svg" Width="18"
                                 Height="18" />
                    </Button>
                    <Button x:Name="TipsButton"
                            VerticalAlignment="Center"
                            Height="28"
                            Padding="6,3"
                            Background="Transparent"
                            BorderThickness="0"
                            ToolTip.Tip="{x:Static text:UiText+Tip.Tips}"
                            Click="OnTipsButton">
                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4a1.svg" Width="18" Height="18" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="DownloadBar"
                DockPanel.Dock="Bottom"
                IsVisible="False"
                Background="{DynamicResource AppColHeaderBrush}"
                BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,6">
            <Grid ColumnDefinitions="*,Auto,120">
                <ProgressBar x:Name="DownloadProgressBar"
                             Grid.Column="0"
                             Minimum="0" Maximum="100"
                             Height="6"
                             VerticalAlignment="Center" />
                <TextBlock x:Name="DownloadSizeText"
                           Grid.Column="1"
                           Margin="10,0"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource AppSubTextBrush}" />
                <TextBlock x:Name="DownloadSpeedText"
                           Grid.Column="2"
                           TextAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource AppSubTextBrush}" />
            </Grid>
        </Border>

        <Grid RowDefinitions="Auto,*">

            <!-- Fixed column header (detail mode only) -->
            <Border x:Name="ColumnHeaderBar" Grid.Row="0" Classes="columnHeader" Margin="8,0"
                    IsVisible="False">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Left" Width="36" Text="" />

                    <TextBlock DockPanel.Dock="Left" Width="{Binding Columns.Name}"
                               Text="{Binding Columns.NameHeader}"
                               Margin="4,0,0,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Name" Tapped="OnColumnHeaderTapped" />
                    <Thumb Classes="colResizer" DockPanel.Dock="Left"
                           Tag="Name" DragDelta="OnColumnResize" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           IsVisible="{Binding Columns.ShowUsedColumn}"
                           Tag="Used" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Used}"
                               IsVisible="{Binding Columns.ShowUsedColumn}"
                               Text="{Binding Columns.UsedHeader}"
                               TextAlignment="Right" Margin="0,0,4,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Used" Tapped="OnColumnHeaderTapped" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           IsVisible="{Binding Columns.ShowMetaColumns}"
                           Tag="Install" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Install}"
                               IsVisible="{Binding Columns.ShowMetaColumns}"
                               Text="{Binding Columns.InstallHeader}"
                               TextAlignment="Right" Margin="0,0,4,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Install" Tapped="OnColumnHeaderTapped" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           IsVisible="{Binding Columns.ShowMetaColumns}"
                           Tag="Download" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Download}"
                               IsVisible="{Binding Columns.ShowMetaColumns}"
                               Text="{Binding Columns.DownloadHeader}"
                               TextAlignment="Right" Margin="0,0,4,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Download" Tapped="OnColumnHeaderTapped" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           Tag="Version" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Version}"
                               Text="{Binding Columns.VersionHeader}"
                               TextAlignment="Right" Margin="0,0,4,0"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Version" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           Tag="Updated" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Updated}"
                               Text="{Binding Columns.UpdatedHeader}"
                               TextAlignment="Right" Margin="0,0,4,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Updated" Tapped="OnColumnHeaderTapped" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           IsVisible="{Binding Columns.ShowCurrentColumn}"
                           Tag="Current" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Current}"
                               IsVisible="{Binding Columns.ShowCurrentColumn}"
                               Text="{Binding Columns.CurrentHeader}"
                               TextAlignment="Right" Margin="0,0,4,0"
                               FontSize="{Binding Columns.FontSizeSub}" />

                    <Thumb Classes="colResizer" DockPanel.Dock="Right"
                           IsVisible="{Binding Columns.ShowJoinedColumn}"
                           Tag="Joined" DragDelta="OnColumnResize" />
                    <TextBlock DockPanel.Dock="Right" Width="{Binding Columns.Joined}"
                               IsVisible="{Binding Columns.ShowJoinedColumn}"
                               Text="{Binding Columns.JoinedHeader}"
                               TextAlignment="Right" Margin="0,0,4,0" Cursor="Hand"
                               FontSize="{Binding Columns.FontSizeSub}"
                               Tag="Joined" Tapped="OnColumnHeaderTapped" />

                    <TextBlock Text="{x:Static text:UiText+Column.MainDescription}" Margin="4,0,0,0"
                               FontSize="{Binding Columns.FontSizeSub}" />
                </DockPanel>
            </Border>

            <!-- Scrollable content + sticky header overlay -->
            <Grid Grid.Row="1">
                <ScrollViewer x:Name="MainScroller"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Detail list -->
                        <ItemsControl x:Name="MainList" ItemsSource="{Binding FlatRows}" Margin="8,0,8,8"
                                      IsVisible="{Binding !Columns.IsGridView}">
                            <ItemsControl.DataTemplates>

                                <!-- Subcategory header with expand/collapse toggle -->
                                <DataTemplate x:DataType="vm:SubCategoryNode">
                                    <Border Classes="subCategoryHeader"
                                            Tapped="OnSubCategoryHeaderTapped">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▼"
                                                       IsVisible="{Binding IsExpanded}"
                                                       FontSize="9"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▶"
                                                       IsVisible="{Binding !IsExpanded}"
                                                       FontSize="9"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{Binding Columns.FontSizeSub}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>

                                <!-- Category header with expand/collapse toggle -->
                                <DataTemplate x:DataType="vm:CategoryNode">
                                    <Border Classes="categoryHeader"
                                            IsVisible="{Binding HasCategory}"
                                            Tapped="OnCategoryHeaderTapped">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▼"
                                                       IsVisible="{Binding IsExpanded}"
                                                       FontSize="10"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▶"
                                                       IsVisible="{Binding !IsExpanded}"
                                                       FontSize="10"
                                                       Opacity="0.6"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0" />
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{Binding Columns.FontSize}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>

                                <!-- App row -->
                                <DataTemplate x:DataType="vm:AppNode">
                                    <Border Classes="appRow"
                                            Classes.installedRow="{Binding IsHighlighted}"
                                            Classes.updateRow="{Binding NeedsUpdate}"
                                            Classes.queuedRow="{Binding IsQueued}"
                                            Classes.activeInstallRow="{Binding IsBeingInstalled}"
                                            Classes.launchFxRow="{Binding IsLaunchFx}"
                                            Classes.indentedRow="{Binding IsIndented}"
                                            Classes.searchFxRow="{Binding IsSearchFx}"
                                            PointerPressed="OnAppRowPointerPressed"
                                            Tapped="OnAppRowTapped">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{x:Static text:UiText+Menu.CancelInstallation}"
                                                          IsVisible="{Binding ShowCancelInstall}"
                                                          Click="OnMenuCancelInstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/26d4.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.AddToQueue}"
                                                          IsVisible="{Binding ShowAddToQueue}"
                                                          Click="OnMenuAddToQueue">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RemoveFromQueue}"
                                                          IsVisible="{Binding ShowRemoveFromQueue}"
                                                          Click="OnMenuRemoveFromQueue">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e4.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator>
                                                    <Separator.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.Or}">
                                                            <Binding Path="ShowCancelInstall" />
                                                            <Binding Path="ShowAddToQueue" />
                                                            <Binding Path="ShowRemoveFromQueue" />
                                                        </MultiBinding>
                                                    </Separator.IsVisible>
                                                </Separator>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Install}"
                                                          IsVisible="{Binding ShowInstallActions}"
                                                          Click="OnMenuInstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.InstallAndRun}"
                                                          IsVisible="{Binding ShowInstallActions}"
                                                          Click="OnMenuInstallRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e9.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Update}"
                                                          IsVisible="{Binding ShowUpdateActions}"
                                                          Click="OnMenuUpdate">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.UpdateAndRun}"
                                                          IsVisible="{Binding ShowUpdateActions}"
                                                          Click="OnMenuUpdateRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e9.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Run}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f3c3.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RunWithParameters}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuRunWithArgs">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f680.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RunAsAdministrator}"
                                                          Click="OnMenuRunAsAdmin">
                                                    <MenuItem.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.And}">
                                                            <Binding Path="ShowRunActions" />
                                                            <Binding Source="{x:Static views:MainWindow.IsWindows}" />
                                                        </MultiBinding>
                                                    </MenuItem.IsVisible>
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e1.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Terminate}"
                                                          IsVisible="{Binding ShowTerminate}"
                                                          Click="OnMenuTerminate">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/2620.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.OpenFolder}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuOpenFolder">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="{x:Static views:MainWindow.OpenFolderIconPath}"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Settings}"
                                                          IsVisible="{Binding IsCustom}"
                                                          Click="OnMenuSettings">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/2699.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator>
                                                    <Separator.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.Or}">
                                                            <Binding Path="ShowInstallActions" />
                                                            <Binding Path="ShowUpdateActions" />
                                                            <Binding Path="ShowRunActions" />
                                                            <Binding Path="IsCustom" />
                                                        </MultiBinding>
                                                    </Separator.IsVisible>
                                                </Separator>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Uninstall}"
                                                          IsVisible="{Binding ShowUninstall}"
                                                          Click="OnMenuUninstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f5d1.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator IsVisible="{Binding ShowUninstall}" />
                                                <MenuItem Header="{x:Static text:UiText+Menu.Preview}"
                                                          IsVisible="{Binding ShowPreview}"
                                                          Click="OnMenuPreview">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f441.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Properties}"
                                                          Click="OnMenuAppDatabaseEntry">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4cb.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.VirusTotal}"
                                                          IsVisible="{Binding ShowVirusTotalActions}"
                                                          Click="OnMenuVirusTotal">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f9a0.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.VisitWebsite}"
                                                          IsVisible="{Binding HasUrl}"
                                                          Click="OnMenuVisitWebsite">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f310.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <DockPanel LastChildFill="True">
                                                <Image DockPanel.Dock="Left"
                                                       Source="{Binding Icon}"
                                                       Width="{Binding Columns.IconSize}"
                                                       Height="{Binding Columns.IconSize}"
                                                       Margin="4,0,4,0"
                                                       VerticalAlignment="Center"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                                                <TextBlock DockPanel.Dock="Left"
                                                           Width="{Binding Columns.Name}"
                                                           Text="{Binding Name}"
                                                           Margin="0,0,8,0"
                                                           FontSize="{Binding Columns.FontSize}"
                                                           ToolTip.Tip="{Binding Name}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Used}"
                                                           IsVisible="{Binding Columns.ShowUsedColumn}"
                                                           Text="{Binding UsedSize}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Install}"
                                                           IsVisible="{Binding Columns.ShowMetaColumns}"
                                                           Text="{Binding InstallSize}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Download}"
                                                           IsVisible="{Binding Columns.ShowMetaColumns}"
                                                           Text="{Binding DownloadSize}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Version}"
                                                           Text="{Binding ShownVersion}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Updated}"
                                                           Text="{Binding UpdateDateDisplay}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Current}"
                                                           IsVisible="{Binding Columns.ShowCurrentColumn}"
                                                           Text="{Binding CurrentDate}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}"
                                                           FontFamily="Cascadia Mono,Consolas,DejaVu Sans Mono,monospace" />
                                                <TextBlock DockPanel.Dock="Right"
                                                           Width="{Binding Columns.Joined}"
                                                           IsVisible="{Binding Columns.ShowJoinedColumn}"
                                                           Text="{Binding JoinedDateDisplay}"
                                                           TextAlignment="Right" Margin="0,0,4,0"
                                                           FontSize="{Binding Columns.FontSize}" />
                                                <TextBlock Text="{Binding Description}" Margin="4,0,0,0"
                                                           FontSize="{Binding Columns.FontSize}"
                                                           ToolTip.Tip="{Binding Description}" />
                                            </DockPanel>
                                            <Rectangle Width="3" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                                       Fill="#4CAF50" IsVisible="{Binding IsRunning}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>

                            </ItemsControl.DataTemplates>
                        </ItemsControl>

                        <!-- Grid / tile view -->
                        <ItemsControl x:Name="MainGridList" ItemsSource="{Binding FlatRows}" Margin="8,0,8,8"
                                      IsVisible="{Binding Columns.IsGridView}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.DataTemplates>

                                <DataTemplate x:DataType="vm:SubCategoryNode">
                                    <Border Classes="subCategoryHeader"
                                            Margin="0,4,0,0"
                                            Width="{Binding $parent[ItemsControl].Bounds.Width}"
                                            Tapped="OnSubCategoryHeaderTapped">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▼" IsVisible="{Binding IsExpanded}"
                                                       FontSize="9" Opacity="0.6"
                                                       VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▶" IsVisible="{Binding !IsExpanded}"
                                                       FontSize="9" Opacity="0.6"
                                                       VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="{Binding Columns.FontSizeSub}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>

                                <DataTemplate x:DataType="vm:CategoryNode">
                                    <Border Classes="categoryHeader"
                                            IsVisible="{Binding HasCategory}"
                                            Width="{Binding $parent[ItemsControl].Bounds.Width}"
                                            Tapped="OnCategoryHeaderTapped">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▼" IsVisible="{Binding IsExpanded}"
                                                       FontSize="10" Opacity="0.6"
                                                       VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock DockPanel.Dock="Right"
                                                       Text="▶" IsVisible="{Binding !IsExpanded}"
                                                       FontSize="10" Opacity="0.6"
                                                       VerticalAlignment="Center" Margin="4,0,0,0" />
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{Binding Columns.FontSize}" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>

                                <DataTemplate x:DataType="vm:AppNode">
                                    <Border Classes="appRow"
                                            Classes.installedRow="{Binding IsHighlighted}"
                                            Classes.updateRow="{Binding NeedsUpdate}"
                                            Classes.queuedRow="{Binding IsQueued}"
                                            Classes.activeInstallRow="{Binding IsBeingInstalled}"
                                            Classes.launchFxRow="{Binding IsLaunchFx}"
                                            Classes.searchFxRow="{Binding IsSearchFx}"
                                            Width="{Binding Columns.TileWidth}"
                                            Padding="4,6"
                                            PointerPressed="OnAppRowPointerPressed"
                                            Tapped="OnAppRowTapped">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="{x:Static text:UiText+Menu.CancelInstallation}"
                                                          IsVisible="{Binding ShowCancelInstall}"
                                                          Click="OnMenuCancelInstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/26d4.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.AddToQueue}"
                                                          IsVisible="{Binding ShowAddToQueue}"
                                                          Click="OnMenuAddToQueue">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RemoveFromQueue}"
                                                          IsVisible="{Binding ShowRemoveFromQueue}"
                                                          Click="OnMenuRemoveFromQueue">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e4.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator>
                                                    <Separator.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.Or}">
                                                            <Binding Path="ShowCancelInstall" />
                                                            <Binding Path="ShowAddToQueue" />
                                                            <Binding Path="ShowRemoveFromQueue" />
                                                        </MultiBinding>
                                                    </Separator.IsVisible>
                                                </Separator>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Install}"
                                                          IsVisible="{Binding ShowInstallActions}"
                                                          Click="OnMenuInstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.InstallAndRun}"
                                                          IsVisible="{Binding ShowInstallActions}"
                                                          Click="OnMenuInstallRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e9.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Update}"
                                                          IsVisible="{Binding ShowUpdateActions}"
                                                          Click="OnMenuUpdate">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.UpdateAndRun}"
                                                          IsVisible="{Binding ShowUpdateActions}"
                                                          Click="OnMenuUpdateRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e9.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Run}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuRun">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f3c3.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RunWithParameters}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuRunWithArgs">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f680.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.RunAsAdministrator}"
                                                          Click="OnMenuRunAsAdmin">
                                                    <MenuItem.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.And}">
                                                            <Binding Path="ShowRunActions" />
                                                            <Binding Source="{x:Static views:MainWindow.IsWindows}" />
                                                        </MultiBinding>
                                                    </MenuItem.IsVisible>
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f6e1.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Terminate}"
                                                          IsVisible="{Binding ShowTerminate}"
                                                          Click="OnMenuTerminate">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/2620.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.OpenFolder}"
                                                          IsVisible="{Binding ShowRunActions}"
                                                          Click="OnMenuOpenFolder">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="{x:Static views:MainWindow.OpenFolderIconPath}"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Settings}"
                                                          IsVisible="{Binding IsCustom}"
                                                          Click="OnMenuSettings">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/2699.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator>
                                                    <Separator.IsVisible>
                                                        <MultiBinding Converter="{x:Static conv:BoolConverters.Or}">
                                                            <Binding Path="ShowInstallActions" />
                                                            <Binding Path="ShowUpdateActions" />
                                                            <Binding Path="ShowRunActions" />
                                                            <Binding Path="IsCustom" />
                                                        </MultiBinding>
                                                    </Separator.IsVisible>
                                                </Separator>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Uninstall}"
                                                          IsVisible="{Binding ShowUninstall}"
                                                          Click="OnMenuUninstall">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f5d1.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator IsVisible="{Binding ShowUninstall}" />
                                                <MenuItem Header="{x:Static text:UiText+Menu.Preview}"
                                                          IsVisible="{Binding ShowPreview}"
                                                          Click="OnMenuPreview">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f441.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.Properties}"
                                                          Click="OnMenuAppDatabaseEntry">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4cb.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.VirusTotal}"
                                                          IsVisible="{Binding ShowVirusTotalActions}"
                                                          Click="OnMenuVirusTotal">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f9a0.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="{x:Static text:UiText+Menu.VisitWebsite}"
                                                          IsVisible="{Binding HasUrl}"
                                                          Click="OnMenuVisitWebsite">
                                                    <MenuItem.Icon>
                                                        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f310.svg"
                                                                 Width="16" Height="16" />
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <StackPanel HorizontalAlignment="Center" Spacing="4"
                                                        Margin="0,0,0,6">
                                                <Image Source="{Binding Icon}"
                                                       Width="{Binding Columns.IconSize}"
                                                       Height="{Binding Columns.IconSize}"
                                                       HorizontalAlignment="Center"
                                                       RenderOptions.BitmapInterpolationMode="HighQuality" />
                                                <TextBlock Text="{Binding Name}"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="None"
                                                           MaxLines="2"
                                                           FontSize="{Binding Columns.FontSize}"
                                                           VerticalAlignment="Top" />
                                            </StackPanel>
                                            <Rectangle Height="3" HorizontalAlignment="Stretch"
                                                       VerticalAlignment="Bottom"
                                                       Fill="#4CAF50" IsVisible="{Binding IsRunning}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>

                            </ItemsControl.DataTemplates>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
                <Border x:Name="StickyHeader"
                        VerticalAlignment="Top"
                        Margin="8,0,8,0"
                        IsVisible="False"
                        ZIndex="1"
                        Background="{DynamicResource AppCategoryBrush}"
                        Padding="8,5"
                        CornerRadius="4,4,0,0"
                        Cursor="Hand"
                        Tapped="OnStickyHeaderTapped">
                    <TextBlock x:Name="StickyHeaderText"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Foreground="{DynamicResource AppTextBrush}" />
                </Border>

                <Border x:Name="LoadingOverlay"
                        ZIndex="2"
                        ClipToBounds="True"
                        Background="{DynamicResource AppWindowBrush}">
                    <Grid>
                        <StackPanel x:Name="ListSkeleton" Margin="20,4,20,8" Spacing="4"
                                    HorizontalAlignment="Stretch" />
                        <UniformGrid x:Name="GridSkeleton" Margin="8,4,8,8" IsVisible="False"
                                     HorizontalAlignment="Stretch" />
                        <StackPanel x:Name="CategoryGridSkeleton" Margin="8,4,8,8" Spacing="10"
                                    IsVisible="False" HorizontalAlignment="Stretch" />
                    </Grid>
                </Border>
            </Grid>

        </Grid>

    </DockPanel>
</Window>