<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apportia.Views.JavaRequiredDialog"
        Title="Java Required"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock x:Name="AppLabel"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}" />

        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextBrush}">
            <Run Text="This app requires a Java runtime to function." />
            <LineBreak />
            <LineBreak />
            <Run Text="Select one or more Java plugins to add to the install queue:" />
        </TextBlock>

        <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="JavaList"
                     MaxHeight="200"
                     Background="Transparent"
                     SelectionMode="Toggle,Multiple" />
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,4,0,0">
            <Button Content="Add to Queue" Click="OnAdd" />
            <Button Content="Cancel" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>