<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:text="using:Apportia.Text"
        xmlns:views="using:Apportia.Views"
        x:Class="Apportia.Views.RunArgsDialog"
        Title="{x:Static text:UiText+Dialog.RunArgsTitle}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="4">

        <TextBlock x:Name="AppLabel"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}"
                   Margin="0,0,0,8" />

        <TextBlock Text="{x:Static text:UiText+Dialog.RunArgsParameters}"
                   FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                   Margin="0,0,0,2" />

        <ListBox x:Name="ArgsList"
                 MaxHeight="240"
                 Background="Transparent"
                 BorderBrush="{DynamicResource AppSeparatorBrush}"
                 BorderThickness="1"
                 CornerRadius="4"
                 Padding="4"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerTheme>
                <ControlTheme TargetType="ListBoxItem" x:DataType="views:ArgItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,4" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Template">
                        <ControlTemplate>
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Background="{TemplateBinding Background}"
                                              HorizontalContentAlignment="Stretch"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}" />
                        </ControlTemplate>
                    </Setter>
                </ControlTheme>
            </ListBox.ItemContainerTheme>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="views:ArgItem">
                    <Grid ColumnDefinitions="*,Auto" Margin="0,0,4,0">
                        <TextBox Grid.Column="0"
                                 Text="{Binding Value, Mode=TwoWay}"
                                 FontFamily="Cascadia Mono,Consolas,DejaVu Sans Mono,monospace"
                                 HorizontalAlignment="Stretch"
                                 MinWidth="0" />
                        <Button Grid.Column="1"
                                Content="{x:Static text:UiText+Button.RemoveArg}"
                                Padding="6,2"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                Click="OnRemoveArg" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
            <Button Content="{x:Static text:UiText+Button.AddParameter}" Click="OnAddArg" />
            <Button Content="{x:Static text:UiText+Button.AddFile}" Click="OnAddFile" />
            <Button Content="{x:Static text:UiText+Button.AddFolder}" Click="OnAddFolder" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,16,0,0">
            <Button x:Name="RunButton" Content="{x:Static text:UiText+Button.Run}" Click="OnRunWithArgs" />
            <Button x:Name="RunAsAdminButton" Content="{x:Static text:UiText+Button.RunAsAdministrator}"
                    Click="OnRunAsAdmin" />
            <Button Content="{x:Static text:UiText+Button.RunWithoutParameters}" Click="OnRunWithoutArgs" />
            <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>