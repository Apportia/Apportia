<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.RunArgsDialog"
        Title="{x:Static text:UiText+Dialog.RunArgsTitle}"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="4">

        <TextBlock x:Name="AppLabel"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}"
                   Margin="0,0,0,8" />

        <TextBlock Text="{x:Static text:UiText+Dialog.RunArgsParameters}"
                   FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                   Margin="0,0,0,2" />

        <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="1" CornerRadius="4" Padding="4">
            <ScrollViewer MaxHeight="200"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,2,6,0">
                <StackPanel x:Name="ArgsList" Spacing="4" Margin="2,2,2,6" />
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
            <Button Content="{x:Static text:UiText+Button.AddParameter}" Click="OnAddArg" />
            <Button Content="{x:Static text:UiText+Button.AddFile}" Click="OnAddFile" />
            <Button Content="{x:Static text:UiText+Button.AddFolder}" Click="OnAddFolder" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,16,0,0">
            <Button x:Name="RunButton" Content="{x:Static text:UiText+Button.Run}" Click="OnRunWithArgs" />
            <Button x:Name="RunAsAdminButton" Content="{x:Static text:UiText+Button.RunAsAdministrator}"
                    Click="OnRunAsAdmin" />
            <Button Content="{x:Static text:UiText+Button.RunWithoutParameters}" Click="OnRunWithoutArgs" />
            <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>