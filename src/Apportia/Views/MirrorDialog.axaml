<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apportia.Views.MirrorDialog"
        Title="Connection Timed Out"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock x:Name="AppLabel"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}" />

        <TextBlock x:Name="FailedMirrorText"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextBrush}" />

        <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="MirrorList"
                     MaxHeight="200"
                     Background="Transparent"
                     SelectionMode="Single" />
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,4,0,0">
            <Button Content="Retry" Click="OnRetry" />
            <Button Content="Cancel" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>