<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Apportia.Views.TipsDialog"
        Title="Tips &amp; Shortcuts"
        Width="740"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="16">

        <!-- Header -->
        <StackPanel Spacing="4">
            <TextBlock Text="Tips &amp; Shortcuts"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock Text="Everything you need to get the most out of Apportia."
                       Foreground="{DynamicResource AppSubTextBrush}"
                       FontSize="12" />
        </StackPanel>

        <!-- Cards -->
        <Grid x:Name="TipsContent" Opacity="0" ColumnDefinitions="*,8,*">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut" />
                </Transitions>
            </Grid.Transitions>

            <!-- Left column -->
            <StackPanel Grid.Column="0" Spacing="6">

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128269;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Ctrl+F — Jump to Search" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="Press Ctrl+F from anywhere to focus the search box instantly."
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#9000;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Ctrl+Click — Install Without Dialog" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Hold Ctrl while clicking an uninstalled app to install it directly or add it to the queue — no prompts. Perfect for installing multiple apps in quick succession."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128444;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Preview — See a Screenshot" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Right-click any app and choose Preview to view a screenshot before installing."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128737;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="VirusTotal — Scan Before You Run" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Right-click any app and choose VirusTotal... to scan it by hash or upload it directly. Results appear inline — no browser needed. Requires a free API key."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128229;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Custom App Import" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Use the Import App button to integrate portable apps from any source into Apportia. Apps are added as-is — Apportia does not make them portable."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128202;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Sortable Columns — Including Disk Usage" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Click any column header to sort. The disk usage column shows actual space used per installed app — great for finding what's taking up space."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- Right column -->
            <StackPanel Grid.Column="2" Spacing="6">

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128269;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Ctrl+Enter — Install Without Dialog" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Select an uninstalled app and press Ctrl+Enter to install it immediately, skipping any confirmation dialog."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128640;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="CLI Arguments — Open Files with Any App" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Pass command-line arguments to apps via Run with Parameters... in the context menu. You can also launch Apportia with a file path to open it directly with a supported app."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128190;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="View Presets — Save Your Layout" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Save your current view settings as a preset via the save button. Presets are restored automatically when switching between All, Installed, and Not Installed."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128203;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Properties — Full App Metadata" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Right-click any app and choose Properties to inspect metadata not shown in the list: download URL, file hash, install path, and more."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#128451;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="Backup &amp; Restore App Data" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="Before uninstalling, you can optionally back up an app's data. Reinstall and restore it later with everything intact — perfect for using apps on demand without losing your settings."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppColHeaderBrush}"
                        BorderBrush="#0090FF" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <TextBlock Grid.Column="0" Text="&#9881;" FontSize="18" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="System Integration — Context Menu" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock
                                Text="If Apportia lives at a fixed location, use the included setup scripts to integrate it into your system. This adds Apportia to context menus so you can open files directly from your file manager."
                                TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>

        </Grid>

        <!-- Footer -->
        <Button Content="Got it!" HorizontalAlignment="Right" Click="OnClose" />

    </StackPanel>
</Window>