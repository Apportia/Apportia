<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.TipsDialog"
        Title="{x:Static text:UiText+Dialog.TipsTitle}"
        Width="760"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="16">

        <!-- Header -->
        <Grid>
            <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4a1.svg"
                     Width="64" Height="64"
                     HorizontalAlignment="Right" VerticalAlignment="Center" />
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="{x:Static text:UiText+Dialog.TipsHeader}"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}" />
                <TextBlock Text="{x:Static text:UiText+Dialog.TipsSubtitle}"
                           Foreground="{DynamicResource AppSubTextBrush}"
                           FontSize="13" />
            </StackPanel>
        </Grid>

        <!-- Cards -->
        <Grid x:Name="TipsContent" Opacity="0" ColumnDefinitions="*,8,*">
            <Grid.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseOut" />
                </Transitions>
            </Grid.Transitions>

            <!-- Left column: 1-6 -->
            <StackPanel Grid.Column="0" Spacing="6">

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f50d.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip01Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip01Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f50e.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip02Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip02Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/2328.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip03Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip03Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f680.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip04Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip04Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f9a0.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip05Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip05Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f4be.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip06Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip06Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>

            <!-- Right column: 7-12 -->
            <StackPanel Grid.Column="2" Spacing="6">

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f441.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip07Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip07Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f4ca.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip08Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip08Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f4cb.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip09Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip09Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f4e5.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip10Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip10Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f5c3.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip11Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip11Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Background="{DynamicResource AppCategoryBrush}"
                        BorderBrush="{DynamicResource SystemControlBackgroundAccentBrush}" BorderThickness="3,0,0,0"
                        CornerRadius="0,6,6,0" Padding="12,10">
                    <Grid ColumnDefinitions="32,*">
                        <svg:Svg Grid.Column="0" Path="avares://Apportia/Assets/Emoji/1f3d7.svg" Width="20" Height="20"
                                 VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip12Title}" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppTextBrush}" />
                            <TextBlock Text="{x:Static text:UiText+Dialog.Tip12Body}"
                                       TextWrapping="Wrap" Foreground="{DynamicResource AppSubTextBrush}" FontSize="13" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>

        </Grid>

        <!-- Footer -->
        <Button Content="{x:Static text:UiText+Button.GotIt}" HorizontalAlignment="Right" Click="OnClose" />

    </StackPanel>
</Window>