<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.CustomAppWindow"
        Width="500"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <Window.Styles>
        <Style Selector="Border.iconThumb">
            <Setter Property="Width" Value="52" />
            <Setter Property="Height" Value="52" />
            <Setter Property="Padding" Value="4" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style Selector="Border.iconThumb:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppHoverBrush}" />
        </Style>
        <Style Selector="Border.iconThumb.selected">
            <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="Background" Value="{DynamicResource AppInstalledBrush}" />
        </Style>
    </Window.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" Spacing="4">

            <StackPanel x:Name="FolderSection">
                <TextBlock Text="{x:Static text:UiText+Header.CustomFolder}"
                           FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                           Margin="0,8,0,2" />
                <Grid ColumnDefinitions="*,8,Auto">
                    <TextBox x:Name="FolderBox" Grid.Column="0" IsReadOnly="True"
                             Foreground="{DynamicResource AppTextBrush}" />
                    <Button x:Name="FolderBrowseButton" Grid.Column="2" Content="{x:Static text:UiText+Button.Browse}"
                            Click="OnBrowseFolder" />
                </Grid>
            </StackPanel>

            <TextBlock Text="{x:Static text:UiText+Header.CustomExecutable}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <ComboBox x:Name="ExeSourceCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnExeSelectionChanged" />

            <StackPanel x:Name="SectionSection">
                <TextBlock Text="{x:Static text:UiText+Header.CustomSection}"
                           FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                           Margin="0,8,0,2" />
                <TextBox x:Name="SectionBox" Foreground="{DynamicResource AppTextBrush}"
                         TextChanged="OnSectionBoxTextChanged" />
            </StackPanel>

            <TextBlock Text="{x:Static text:UiText+Header.CustomName}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <TextBox x:Name="NameBox" Foreground="{DynamicResource AppTextBrush}" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomDescription}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <TextBox x:Name="DescriptionBox" Foreground="{DynamicResource AppTextBrush}" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomCategory}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <ComboBox x:Name="CategoryCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnCategorySelectionChanged" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomSubCategory}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <ComboBox x:Name="SubCategoryCombo" HorizontalAlignment="Stretch" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomWebsite}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <TextBox x:Name="WebsiteBox" Foreground="{DynamicResource AppTextBrush}" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomVersionSource}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <ComboBox x:Name="VersionSourceCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnVersionExeSelectionChanged" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomVersion}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <TextBox x:Name="VersionBox" Foreground="{DynamicResource AppTextBrush}" />
            <TextBlock x:Name="VersionChangedText"
                       IsVisible="False"
                       FontSize="11" Foreground="#E0A020"
                       TextWrapping="Wrap"
                       Margin="0,2,0,0" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomIconSource}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />
            <ComboBox x:Name="IconSourceCombo" HorizontalAlignment="Stretch"
                      SelectionChanged="OnIconExeSelectionChanged" />

            <TextBlock Text="{x:Static text:UiText+Header.CustomIcon}"
                       FontSize="11" Foreground="{DynamicResource AppSubTextBrush}"
                       Margin="0,8,0,2" />

            <Border x:Name="IconGalleryBorder"
                    IsVisible="False"
                    BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,4">
                <ScrollViewer x:Name="IconScrollViewer"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              Padding="2"
                              PointerWheelChanged="OnIconScrollWheel">
                    <StackPanel x:Name="IconGallery" Orientation="Horizontal" Margin="4,4,4,20" />
                </ScrollViewer>
            </Border>

            <Grid ColumnDefinitions="*,8,Auto">
                <TextBox x:Name="IconBox" Grid.Column="0" IsReadOnly="True"
                         Foreground="{DynamicResource AppSubTextBrush}"
                         PlaceholderText="{x:Static text:UiText+Placeholder.CustomAppIconPath}" />
                <Button Grid.Column="2" Content="{x:Static text:UiText+Button.Browse}" Click="OnBrowseIcon" />
            </Grid>

            <TextBlock x:Name="ErrorText"
                       IsVisible="False"
                       Foreground="#E05555"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="8" Margin="0,16,0,0">
                <Button x:Name="ActionButton" Click="OnAction" />
                <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Window>
