<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:views="using:Apportia.Views"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.TerminateDialog"
        Title="{x:Static text:UiText+Dialog.TerminateTitle}"
        Width="800"
        Height="600"
        MinWidth="480"
        MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <Panel>
        <svg:Svg Path="avares://Apportia/Assets/Emoji/2620.svg"
                 Width="256" Height="256"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="10,0,0,10"
                 IsHitTestVisible="False"
                 Css="* { opacity: 0.3; }" />

        <DockPanel Margin="20">

            <TextBlock DockPanel.Dock="Top"
                       x:Name="HeaderText"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Foreground="{DynamicResource AppTextBrush}" />

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="8"
                        Margin="0,12,0,0">
                <Button Content="{x:Static text:UiText+Button.TerminateAll}" Click="OnTerminate" IsDefault="True" />
                <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" IsCancel="True" />
            </StackPanel>

            <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="Transparent">
                <DockPanel>
                    <Grid DockPanel.Dock="Top"
                          ColumnDefinitions="70,*,80,2*,32"
                          Background="{DynamicResource AppColHeaderBrush}">
                        <TextBlock Grid.Column="0" Text="{x:Static text:UiText+Column.TerminatePid}"
                                   Padding="8,4" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubTextBrush}" />
                        <TextBlock Grid.Column="1" Text="{x:Static text:UiText+Column.TerminateExecutable}"
                                   Padding="8,4" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubTextBrush}" />
                        <TextBlock Grid.Column="2" Text="{x:Static text:UiText+Column.TerminateStarted}"
                                   Padding="8,4" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubTextBrush}" />
                        <TextBlock Grid.Column="3" Text="{x:Static text:UiText+Column.TerminateCommand}"
                                   Padding="8,4" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubTextBrush}" />
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="GroupList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="views:TerminateGroup">
                                    <StackPanel>
                                        <Border Background="{DynamicResource AppColHeaderBrush}"
                                                BorderBrush="{DynamicResource AppSeparatorBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid ColumnDefinitions="Auto,*,Auto,32">
                                                <Image Grid.Column="0" Source="{Binding Icon}"
                                                       Width="20" Height="20" Margin="8,4" />
                                                <TextBlock Grid.Column="1" Text="{Binding AppName}"
                                                           Padding="4,4" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppTextBrush}" />
                                                <TextBlock Grid.Column="2"
                                                           Text="{Binding Rows.Count, StringFormat='({0})'}"
                                                           Padding="4,4"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource AppSubTextBrush}" />
                                                <Button Grid.Column="3"
                                                        Tag="{Binding}"
                                                        Click="OnTerminateGroup"
                                                        ToolTip.Tip="{x:Static text:UiText+Button.TerminateAll}"
                                                        Padding="4"
                                                        Margin="4,2"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Background="Transparent"
                                                        BorderThickness="0">
                                                    <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4db.svg"
                                                             Width="16" Height="16" />
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="views:TerminateRow">
                                                    <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                                                            BorderThickness="0,0,0,1">
                                                        <Grid ColumnDefinitions="70,*,80,2*,32">
                                                            <TextBlock Grid.Column="0" Text="{Binding PidText}"
                                                                       Padding="8,4"
                                                                       Foreground="{DynamicResource AppTextBrush}"
                                                                       FontFamily="Cascadia Mono,Consolas,DejaVu Sans Mono,monospace" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Exe}"
                                                                       Padding="8,4"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip.Tip="{Binding Exe}"
                                                                       Foreground="{DynamicResource AppTextBrush}" />
                                                            <TextBlock Grid.Column="2" Text="{Binding StartedText}"
                                                                       Padding="8,4"
                                                                       Foreground="{DynamicResource AppTextBrush}"
                                                                       FontFamily="Cascadia Mono,Consolas,DejaVu Sans Mono,monospace" />
                                                            <TextBlock Grid.Column="3" Text="{Binding CommandLine}"
                                                                       Padding="8,4"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip.Tip="{Binding CommandLine}"
                                                                       Foreground="{DynamicResource AppSubTextBrush}" />
                                                            <Button Grid.Column="4"
                                                                    Tag="{Binding}"
                                                                    Click="OnTerminateRow"
                                                                    ToolTip.Tip="{x:Static text:UiText+Button.Terminate}"
                                                                    Padding="4"
                                                                    Margin="4,2"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="Transparent"
                                                                    BorderThickness="0">
                                                                <svg:Svg Path="avares://Apportia/Assets/Emoji/274c.svg"
                                                                         Width="16" Height="16" />
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </DockPanel>
    </Panel>
</Window>