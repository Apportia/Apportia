<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.LinuxSetupDialog"
        Title="{x:Static text:UiText+Dialog.LinuxSetupTitle}"
        Width="460"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <Window.Styles>
        <Style Selector="Button.update">
            <Setter Property="Background" Value="{DynamicResource AppUpdateBrush}" />
        </Style>
        <Style Selector="Button.update:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppUpdateBrush}" />
        </Style>
    </Window.Styles>

    <Panel>
        <svg:Svg Path="avares://Apportia/Assets/Emoji/1f377.svg"
                 Width="128" Height="128"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,30,20,0"
                 IsHitTestVisible="False"
                 Css="* { opacity: 0.35; }" />
        <StackPanel Margin="20" Spacing="12">

            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource AppTextBrush}">
                <Run Text="{x:Static text:UiText+Dialog.LinuxPromptLine1}" />
                <LineBreak />
                <Run Text="{x:Static text:UiText+Dialog.LinuxPromptLine2}" />
            </TextBlock>

            <StackPanel x:Name="SystemWinePanel" Spacing="6" IsVisible="False">
                <TextBlock Text="{x:Static text:UiText+Dialog.LinuxSystemModeInstallation}" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}" />
                <RadioButton x:Name="SystemModeRadio"
                             GroupName="Mode"
                             Content="{x:Static text:UiText+Dialog.LinuxSystemModeSystem}"
                             Foreground="{DynamicResource AppTextBrush}" />
                <RadioButton x:Name="BundledModeRadio"
                             GroupName="Mode"
                             Content="{x:Static text:UiText+Dialog.LinuxSystemModeBundled}"
                             Foreground="{DynamicResource AppTextBrush}"
                             IsCheckedChanged="OnModeChanged" />
            </StackPanel>

            <TextBlock x:Name="SystemWineMissingWarning"
                       IsVisible="False"
                       Text="{x:Static text:UiText+Dialog.LinuxSystemWineMissingWarning}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="#E0A020" />

            <StackPanel x:Name="VersionPanel" Spacing="6">
                <TextBlock Text="{x:Static text:UiText+Dialog.LinuxVersionHeader}" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}" />
                <ComboBox x:Name="VersionCombo" HorizontalAlignment="Stretch"
                          SelectionChanged="OnVersionChanged" />
                <TextBlock x:Name="VersionHint"
                           FontSize="11" TextWrapping="Wrap"
                           Foreground="{DynamicResource AppTextBrush}"
                           Opacity="0.7" />
            </StackPanel>

            <StackPanel x:Name="ProgressPanel" Spacing="4" IsVisible="False">
                <TextBlock x:Name="ProgressText"
                           FontSize="12"
                           Foreground="{DynamicResource AppTextBrush}" />
                <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Height="6" />
            </StackPanel>

            <TextBlock x:Name="ErrorText"
                       IsVisible="False"
                       TextWrapping="Wrap"
                       Foreground="#e57373" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="8" Margin="0,4,0,0">
                <Button x:Name="RetryButton" Content="{x:Static text:UiText+Button.Retry}" IsVisible="False"
                        Click="OnRetry" />
                <Button x:Name="SaveButton" Content="{x:Static text:UiText+Button.Save}" Click="OnSave"
                        IsDefault="True" />
                <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" IsCancel="True" />
            </StackPanel>

        </StackPanel>
    </Panel>
</Window>