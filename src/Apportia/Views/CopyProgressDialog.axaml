<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.CopyProgressDialog"
        Title="{x:Static text:UiText+Dialog.CopyImportHeader}"
        Width="540"
        Height="358"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <Window.Styles>
        <Style Selector="Border.fileRow">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut" />
                </Transitions>
            </Setter>
        </Style>
    </Window.Styles>

    <StackPanel Margin="20" Spacing="14">

        <!-- Header -->
        <Grid ColumnDefinitions="Auto,12,*">
            <svg:Svg Path="avares://Apportia/Assets/Emoji/1f4e5.svg"
                     Width="36" Height="36"
                     VerticalAlignment="Center" />
            <StackPanel Grid.Column="2" Spacing="3" VerticalAlignment="Center">
                <TextBlock Text="{x:Static text:UiText+Dialog.CopyImportHeader}"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}" />
                <TextBlock x:Name="FolderLabel"
                           FontSize="12"
                           Foreground="{DynamicResource AppSubTextBrush}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>

        <!-- Progress bar -->
        <ProgressBar x:Name="CopyProgressBar"
                     Height="6"
                     IsIndeterminate="True"
                     Minimum="0" Maximum="100" />

        <!-- Status text -->
        <TextBlock x:Name="StatusText"
                   Text="{x:Static text:UiText+Dialog.CopyProgressPreparing}"
                   FontSize="12"
                   Foreground="{DynamicResource AppSubTextBrush}" />

        <!-- File list -->
        <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="2">
            <ScrollViewer x:Name="FileScrollViewer"
                          MaxHeight="180"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="FileList" Margin="6,4" Spacing="1" />
            </ScrollViewer>
        </Border>

    </StackPanel>
</Window>