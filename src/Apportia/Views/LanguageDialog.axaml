<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.LanguageDialog"
        Title="{x:Static text:UiText+Dialog.LanguageTitle}"
        Width="320"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <StackPanel Margin="20" Spacing="12">

        <TextBlock x:Name="AppLabel"
                   FontSize="13" FontWeight="SemiBold"
                   Foreground="{DynamicResource AppTextBrush}" />

        <TextBlock TextWrapping="Wrap"
                   Foreground="{DynamicResource AppTextBrush}">
            <Run Text="{x:Static text:UiText+Dialog.LanguagePromptLine1}" />
            <LineBreak />
            <LineBreak />
            <Run Text="{x:Static text:UiText+Dialog.LanguagePromptLine2}" />
        </TextBlock>

        <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="LanguageList"
                     MaxHeight="240"
                     Background="Transparent"
                     SelectionMode="Single" />
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    Spacing="8" Margin="0,4,0,0">
            <Button Content="{x:Static text:UiText+Button.Install}" Click="OnInstall" />
            <Button Content="{x:Static text:UiText+Button.Cancel}" Click="OnCancel" />
        </StackPanel>

    </StackPanel>
</Window>