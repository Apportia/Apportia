<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:Apportia.Views"
        xmlns:text="using:Apportia.Text"
        x:Class="Apportia.Views.LeftoverFilesDialog"
        Title="{x:Static text:UiText+Dialog.LeftoverFilesTitle}"
        SizeToContent="Height"
        Width="460"
        MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppWindowBrush}">

    <DockPanel>

        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource AppSeparatorBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="DeleteButton" Content="{x:Static text:UiText+Button.DeleteAll}" Click="OnDelete" />
                <Button Content="{x:Static text:UiText+Button.Close}" Click="OnClose" />
            </StackPanel>
        </Border>

        <StackPanel Margin="20,16,20,16" Spacing="12">
            <TextBlock TextWrapping="Wrap"
                       Foreground="{DynamicResource AppTextBrush}"
                       Text="{x:Static text:UiText+Dialog.LeftoverFilesBody}" />

            <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                <ScrollViewer MaxHeight="260">
                    <ItemsControl x:Name="ItemList" Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:LeftoverEntry">
                                <Grid ColumnDefinitions="*,60" Margin="10,5,10,5">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource AppTextBrush}" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Kind}"
                                               FontSize="12"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource AppSubTextBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

    </DockPanel>
</Window>